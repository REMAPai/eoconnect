# =============================================================================
# Member Market — production env vars (AWS deployment)
# =============================================================================
# Copy to .env.production on your EC2 / App Runner / ECS task and fill in.
# Never commit the filled version. All NEXT_PUBLIC_* vars are exposed to the
# browser; everything else is server-only.

# ── Supabase (required) ─────────────────────────────────────────────────────
# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...   # anon (public) key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...       # service role — SERVER ONLY, never expose

# ── Site (required) ─────────────────────────────────────────────────────────
# Your production AWS domain. Used for OAuth redirects, email links, OG tags.
# After deploy, also update Supabase → Auth → URL Configuration → Site URL
# AND Google Cloud → OAuth client → Authorized redirect URIs:
#   https://yourdomain.com/auth/callback
NEXT_PUBLIC_SITE_URL=https://membermarket.io

# ── OpenAI (required for search + AI parser) ────────────────────────────────
# Models in use: gpt-5-nano (parser), text-embedding-3-small (vector search).
# Get from platform.openai.com → API keys
OPENAI_API_KEY=sk-proj-...

# ── Email (required for transactional mail) ─────────────────────────────────
# Resend dashboard → API Keys
RESEND_API_KEY=re_...
EMAIL_FROM="Member Market <noreply@membermarket.io>"

# ── Stripe (required for ad campaign billing) ───────────────────────────────
# Test mode: sk_test_... / pk_test_...
# Live mode:  sk_live_... / pk_live_...
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Stripe Dashboard → Developers → Webhooks → Add endpoint
#   URL:    https://yourdomain.com/api/webhooks/stripe
#   Events: checkout.session.completed, invoice.payment_succeeded,
#           customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cron / scheduled jobs (required on AWS) ─────────────────────────────────
# Vercel injected this implicitly. On AWS, generate a random 32+ char string
# and set the same value as a header on EventBridge rules that hit
# /api/cron/*. Routes verify req.headers.authorization === `Bearer ${CRON_SECRET}`.
#   openssl rand -hex 32
CRON_SECRET=replace-with-32-byte-random-hex

# ── Feature flags (optional) ────────────────────────────────────────────────
# Set 'true' to enable ad campaigns end-to-end. Default 'false' until launch.
ADS_ENABLED=false

# =============================================================================
# AWS deployment checklist (paste into your runbook)
# =============================================================================
# 1.  Build:           npm run build
# 2.  Containerize:    Dockerfile uses output: 'standalone' from next.config.ts
# 3.  Push image:      ECR
# 4.  Run:             App Runner (~$25/mo, simplest) OR ECS Fargate
# 5.  Domain:          Route 53 → ACM cert → CloudFront → service
# 6.  Cron:            EventBridge rules → invoke /api/cron/* with
#                      Bearer ${CRON_SECRET} header
# 7.  Logs:            CloudWatch (or pipe to Logflare/Datadog/etc.)
# 8.  Update Supabase Auth → Site URL + Redirect URLs to new domain
# 9.  Update Google OAuth client → add new redirect URI
# 10. Set ALL of the above env vars on your service
# =============================================================================
